# Community edition baseline
OPENCLAW_HOME=./.openclaw
HOST=0.0.0.0
PORT=7891
PYTHON_BIN=./.venv-backend/bin/python3
OPENCLAW_BIN=openclaw

# Seed profile: clean | demo
RACCOONCLAW_DATA_PROFILE=clean

# Feature tiers
RACCOONCLAW_ENABLE_IM_CHANNELS=false
RACCOONCLAW_ENABLE_TOOLBOX=false
RACCOONCLAW_ENABLE_SCHEDULED_TASKS=false
RACCOONCLAW_ENABLE_AUTOMATION_MIRRORS=false

# Optional local integrations
# FEISHU_DELIVER=false
# OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
